# Required. Server-side only — never prefixed VITE_*.
GOOGLE_API_KEY=

# Required. balldontlie.io fallback for stats.nba.com (Vercel egress IPs are
# frequently 403'd by stats.nba.com). Header value is the raw key, no Bearer.
BALLDONTLIE_API_KEY=

# Optional. When set, api/lib/logger.js forwards log.error() events to
# Sentry. See SENTRY_SETUP.md for setup.
SENTRY_DSN=
